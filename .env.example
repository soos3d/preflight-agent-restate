# Anthropic API key — required. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Claude model used for briefings. Defaults to a current Sonnet-class model.
ANTHROPIC_MODEL=claude-sonnet-5

# Restate ingress URL (used by the pilot UI proxy). Default works for a local restate-server.
RESTATE_URL=http://localhost:8080

# Set to "true" to add artificial latency inside journaled steps.
# This widens the window for the kill -9 recovery demo — see README "Kill it".
SLOW_MODE=false
