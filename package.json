{
  "name": "preflight-agent",
  "version": "0.1.0",
  "description": "Durable AI flight-briefing agent built on Restate and the Anthropic SDK",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "start": "tsx src/app.ts",
    "ui": "tsx src/ui-server.ts",
    "build": "tsc --noEmitOnError",
    "test": "vitest run",
    "test:e2e": "RUN_E2E=1 vitest run tests/e2e.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "@restatedev/restate-sdk": "^1.16.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@restatedev/restate-sdk-clients": "^1.16.2",
    "@restatedev/restate-sdk-testcontainers": "^1.16.2",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^3.2.7"
  }
}
